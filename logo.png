<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" /><script>
/**
 * Divi Blog Extras Slider - Autoplay bij zichtbaarheid
 * 
 * Dit script zorgt ervoor dat sliders pas starten met autoplay wanneer
 * ze volledig zichtbaar zijn in de viewport. Werkt op desktop, mobiel en iOS.
 * 
 * Installatie:
 * 1. Upload dit bestand naar je WordPress theme folder (bijv. /wp-content/themes/divi-child/js/)
 * 2. Voeg de code uit het bestand 'functions-php-toevoeging.txt' toe aan je functions.php
 * 
 * Of:
 * Kopieer de volledige code hieronder en plak in Divi > Theme Options > 
 * Integratie > "Add code to the < head > of your blog" (binnen <script> tags)
 */

(function() {
    'use strict';
    
    /**
     * Configuratie
     * Pas deze waarden aan indien nodig
     */
    const CONFIG = {
        // Percentage van de slider dat zichtbaar moet zijn voordat autoplay start (0.0 - 1.0)
        visibilityThreshold: 1.0, // 1.0 = 100% zichtbaar
        
        // Pauzeer autoplay wanneer slider uit beeld verdwijnt
        pauseWhenNotVisible: true,
        
        // Selector voor de sliders
        // Gebruik de class die 'el-dbe-blog-extra' bevat
        sliderSelector: '[class*="el-dbe-blog-extra"]',
        
        // Debug mode - zet op true om console logs te zien
        debug: true  // Zet op false na testen
    };
    
    /**
     * Logging functie (alleen actief als debug = true)
     */
    function log(message, data) {
        if (CONFIG.debug) {
            console.log('[Slider Visibility] ' + message, data || '');
        }
    }
    
    /**
     * Check of Intersection Observer beschikbaar is
     */
    function isIntersectionObserverSupported() {
        return 'IntersectionObserver' in window &&
               'IntersectionObserverEntry' in window &&
               'intersectionRatio' in window.IntersectionObserverEntry.prototype;
    }
    
    /**
     * Fallback voor oude browsers
     *Start alle sliders direct (oude gedrag)
     */
    function fallbackAutoplay() {
        log('Intersection Observer niet ondersteund, gebruik fallback');
        const sliders = document.querySelectorAll(CONFIG.sliderSelector);
        sliders.forEach(function(slider) {
            startSliderAutoplay(slider);
        });
    }
    
    /**
     * Start de autoplay van een slider
     */
    function startSliderAutoplay(slider) {
        // Divi Blog Extras gebruikt Swiper.js
        // We zoeken het Swiper instance
        
        // Methode 1: Via Swiper instance opgeslagen in het element
        if (slider.swiper) {
            log('Autoplay gestart via slider.swiper', slider);
            slider.swiper.autoplay.start();
            slider.classList.add('autoplay-started');
            return true;
        }
        
        // Methode 2: Via data-attribute of class
        const swiperContainer = slider.querySelector('.swiper-container') || slider;
        if (swiperContainer && swiperContainer.swiper) {
            log('Autoplay gestart via swiper-container', swiperContainer);
            swiperContainer.swiper.autoplay.start();
            slider.classList.add('autoplay-started');
            return true;
        }
        
        // Methode 3: Trigger event voor andere slider libraries
        const playEvent = new CustomEvent('startAutoplay');
        slider.dispatchEvent(playEvent);
        log('Custom event startAutoplay getriggerd', slider);
        slider.classList.add('autoplay-started');
        
        return false;
    }
    
    /**
     * Stop de autoplay van een slider
     */
    function stopSliderAutoplay(slider) {
        if (slider.swiper) {
            log('Autoplay gestopt via slider.swiper', slider);
            slider.swiper.autoplay.stop();
            slider.classList.remove('autoplay-started');
            return true;
        }
        
        const swiperContainer = slider.querySelector('.swiper-container') || slider;
        if (swiperContainer && swiperContainer.swiper) {
            log('Autoplay gestopt via swiper-container', swiperContainer);
            swiperContainer.swiper.autoplay.stop();
            slider.classList.remove('autoplay-started');
            return true;
        }
        
        const stopEvent = new CustomEvent('stopAutoplay');
        slider.dispatchEvent(stopEvent);
        log('Custom event stopAutoplay getriggerd', slider);
        slider.classList.remove('autoplay-started');
        
        return false;
    }
    
    /**
     * Initialiseer Intersection Observer voor sliders
     */
    function initSliderObserver() {
        log('Initialiseer Slider Observer');
        
        // Maak observer aan
        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                const slider = entry.target;
                
                // Check of slider volledig zichtbaar is (of voldoende zichtbaar volgens threshold)
                if (entry.isIntersecting && entry.intersectionRatio >= CONFIG.visibilityThreshold) {
                    log('Slider is zichtbaar geworden', {
                        ratio: entry.intersectionRatio,
                        slider: slider
                    });
                    
                    // Kleine delay om er zeker van te zijn dat Swiper geïnitialiseerd is
                    setTimeout(function() {
                        startSliderAutoplay(slider);
                    }, 100);
                    
                } else if (!entry.isIntersecting && CONFIG.pauseWhenNotVisible) {
                    // Slider is uit beeld verdwenen
                    log('Slider is uit beeld verdwenen', slider);
                    
                    if (slider.classList.contains('autoplay-started')) {
                        stopSliderAutoplay(slider);
                    }
                }
            });
        }, {
            threshold: CONFIG.visibilityThreshold,
            // rootMargin kan gebruikt worden om al te starten voordat slider volledig zichtbaar is
            // bijv. rootMargin: '50px' start 50px voordat slider in beeld komt
            rootMargin: '0px'
        });
        
        // Zoek alle sliders en observeer ze
        const sliders = document.querySelectorAll(CONFIG.sliderSelector);
        log('Aantal gevonden sliders: ' + sliders.length);
        
        sliders.forEach(function(slider) {
            // Stop initiële autoplay als die al draait
            stopSliderAutoplay(slider);
            
            // Start observeren
            observer.observe(slider);
            log('Slider wordt geobserveerd', slider);
        });
    }
    
    /**
     * Wacht tot Divi Blog Extras en Swiper geladen zijn
     */
    function waitForSliderInit() {
        // Check of er al sliders aanwezig zijn
        const sliders = document.querySelectorAll(CONFIG.sliderSelector);
        
        if (sliders.length > 0) {
            log('Sliders gevonden, initialiseer observer');
            
            // Wacht even om er zeker van te zijn dat Swiper geïnitialiseerd is
            setTimeout(function() {
                if (isIntersectionObserverSupported()) {
                    initSliderObserver();
                } else {
                    fallbackAutoplay();
                }
            }, 500);
        } else {
            log('Nog geen sliders gevonden, probeer opnieuw over 500ms');
            
            // Probeer opnieuw na 500ms (max 10 pogingen = 5 seconden)
            if (!window.sliderInitAttempts) {
                window.sliderInitAttempts = 0;
            }
            
            if (window.sliderInitAttempts < 10) {
                window.sliderInitAttempts++;
                setTimeout(waitForSliderInit, 500);
            } else {
                log('Max pogingen bereikt, geen sliders gevonden');
            }
        }
    }
    
    /**
     * Initialisatie bij DOM ready
     */
    function init() {
        log('Script geladen en gestart');
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', waitForSliderInit);
        } else {
            waitForSliderInit();
        }
    }
    
    // Start het script
    init();
    
    /**
     * Herinitialiseer na AJAX laden (voor single page applications)
     * Dit kan handig zijn als je Divi builder gebruikt in de frontend
     */
    if (window.et_pb_custom) {
        document.addEventListener('et_pb_after_init_modules', function() {
            log('Divi modules opnieuw geïnitialiseerd, herstart observer');
            waitForSliderInit();
        });
    }
    
})();
